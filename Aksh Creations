<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Elite Fashion Store</title>
    <script src="https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js"></script>
    <style>
        :root { --gold: #c5a059; --dark: #1a1a1a; --light: #f4f4f4; }
        body { font-family: 'Segoe UI', sans-serif; margin: 0; background: var(--light); }
        
        /* Navigation */
        nav { background: var(--dark); color: white; padding: 1rem; display: flex; justify-content: space-between; position: sticky; top: 0; z-index: 100; }
        nav a { color: white; margin: 0 15px; text-decoration: none; cursor: pointer; }

        /* Tabs */
        .page { display: none; padding: 20px; }
        .active { display: block; }

        /* Product Grid */
        .gallery { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 20px; }
        .card { background: white; padding: 15px; border-radius: 8px; box-shadow: 0 4px 8px rgba(0,0,0,0.1); text-align: center; }
        .card img { max-width: 100%; height: 200px; object-fit: cover; border-radius: 5px; }
        .price { color: #27ae60; font-weight: bold; font-size: 1.2rem; }

        /* Form */
        .form-container { max-width: 500px; margin: auto; background: white; padding: 30px; border-radius: 10px; }
        input, select, button { width: 100%; padding: 10px; margin: 10px 0; border: 1px solid #ddd; border-radius: 5px; }
        button { background: var(--gold); color: white; border: none; cursor: pointer; font-weight: bold; }

        /* Payment Modal */
        #payment-modal { display:none; position:fixed; top:50%; left:50%; transform:translate(-50%, -50%); background:white; padding:20px; border:2px solid var(--gold); z-index:1000; text-align:center; }
    </style>
</head>
<body>

<nav>
    <div class="logo"><strong>ELITE FASHION</strong></div>
    <div>
        <a onclick="showPage('shop')">Shop Gallery</a>
        <a onclick="showPage('upload')">Upload Product</a>
    </div>
</nav>

<div id="shop" class="page active">
    <h2>Fashion Collection</h2>
    <div class="gallery" id="product-display">
        <div class="card">
            <img src="https://images.unsplash.com/photo-1539109132314-34759616b408?auto=format&fit=crop&w=300" alt="Dress">
            <h3>Summer Floral Dress</h3>
            <p class="price">₹1,299</p>
            <button onclick="payNow(1299, 'Summer Floral Dress')">Buy Now</button>
        </div>
    </div>
</div>

<div id="upload" class="page">
    <div class="form-container">
        <h2>Upload New Product</h2>
        <input type="text" id="p-name" placeholder="Product Name (e.g. Silk Saree)">
        <input type="number" id="p-price" placeholder="Price in INR">
        <select id="p-category">
            <option value="Ethnic">Ethnic Wear</option>
            <option value="Western">Western Wear</option>
            <option value="Accessories">Accessories</option>
        </select>
        <input type="text" id="p-img" placeholder="Image URL (Link from web)">
        <button onclick="addProduct()">Publish to Store</button>
    </div>
</div>

<div id="payment-modal">
    <h3>Scan to Pay via UPI</h3>
    <div id="qrcode" style="display: flex; justify-content: center; margin: 15px;"></div>
    <p id="pay-details"></p>
    <p>UPI ID: <strong>adey6547@axl</strong></p>
    <button onclick="this.parentElement.style.display='none'">Close</button>
</div>

<script>
    function showPage(id) {
        document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
        document.getElementById(id).classList.add('active');
    }

    function addProduct() {
        const name = document.getElementById('p-name').value;
        const price = document.getElementById('p-price').value;
        const img = document.getElementById('p-img').value;

        if(!name || !price || !img) return alert("Please fill all fields");

        const display = document.getElementById('product-display');
        const newItem = `
            <div class="card">
                <img src="${img}" alt="product">
                <h3>${name}</h3>
                <p class="price">₹${price}</p>
                <button onclick="payNow(${price}, '${name}')">Buy Now</button>
            </div>`;
        
        display.innerHTML += newItem;
        alert("Product Added Successfully!");
        showPage('shop');
    }

    function payNow(amount, name) {
        const upiId = "adey6547@axl";
        const qrContainer = document.getElementById('qrcode');
        qrContainer.innerHTML = ""; // Clear old QR
        
        // UPI Deep Link Format: upi://pay?pa=ID&pn=NAME&am=AMOUNT&cu=INR
        const upiLink = `upi://pay?pa=${upiId}&pn=EliteFashion&am=${amount}&cu=INR&tn=Payment for ${name}`;
        
        new QRCode(qrContainer, {
            text: upiLink,
            width: 200,
            height: 200
        });

        document.getElementById('pay-details').innerText = `Total: ₹${amount} for ${name}`;
        document.getElementById('payment-modal').style.display = 'block';
    }
</script>

</body>
</html>
